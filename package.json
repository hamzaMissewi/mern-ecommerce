{
  "name": "mern-ecommerce",
  "version": "1.0.0",
  "description": "ecommerce site",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "server": "nodemon --exec ts-node src/server.ts",
    "build": "rimraf dist && tsc",
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "frontend": "npm run dev --prefix frontend",
    "heroku-postbuild": "npm run build && NPM_CONFIG_PRODUCTION=false npm install --prefix frontend && npm run build --prefix frontend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamzaMissewi/mern-ecommerce.git"
  },
  "keywords": [],
  "author": "Hamza M.",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.11.0",
    "body-parser": "^2.2.0",
    "braintree": "^3.33.1",
    "concurrently": "^9.2.0",
    "config": "^4.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-jwt": "^8.5.1",
    "express-validator": "^7.2.1",
    "formidable": "^3.5.4",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongodb": "^6.18.0",
    "mongoose": "^8.17.1",
    "morgan": "^1.10.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/formidable": "^3.5.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/mongoose": "^5.11.96",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}